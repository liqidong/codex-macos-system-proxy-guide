# Copy this file to .env and fill values discovered on your own machine.
# Do not commit .env.

NETWORK_SERVICE="YOUR_MACOS_NETWORK_SERVICE"
PROXY_HOST="YOUR_LOCAL_PROXY_HOST"
PROXY_PORT="YOUR_LOCAL_HTTP_PROXY_PORT"

# SOCKS is optional. By default scripts leave existing SOCKS system proxy
# state unchanged unless one of the two flags below is enabled.
ENABLE_SOCKS_PROXY="0"
DISABLE_SOCKS_PROXY="0"
SOCKS_PROXY_HOST="YOUR_LOCAL_SOCKS_HOST"
SOCKS_PROXY_PORT="YOUR_LOCAL_SOCKS_PORT"

APP_NAME="YOUR_CODEX_APP_NAME"
CLAUDE_APP_NAME="YOUR_CLAUDE_APP_NAME"

TEST_URLS="https://chatgpt.com/ https://openai.com/"
CLAUDE_TEST_URLS="https://claude.ai/ https://claude.com/ https://www.anthropic.com/"
ALLOW_PARTIAL_PROXY_CHECK="0"
